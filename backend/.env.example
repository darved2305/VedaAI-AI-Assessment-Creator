# ════════════════════════════════════════════════════════════════════════════
#  VedaAI Backend — Environment Variables
#
#  HOW TO USE
#  ──────────
#  Local dev  : cp .env.example .env  then fill in values
#  Production : set these in your deployment platform
#               (Railway / Render → Environment Variables)
#
#  SECURITY
#  ────────
#  .env is gitignored. Never commit real values.
#  This file (.env.example) is safe to commit — it has no secrets.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Allowed CORS origin for the frontend
# Local dev  : http://localhost:3000
# Production : https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=vedaai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local  : redis://localhost:6379
# Upstash (managed, production-ready): rediss://:password@host:port
REDIS_URL=redis://localhost:6379

# ── Groq AI ──────────────────────────────────────────────────────────────────
# Get from https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Available models: llama-3.3-70b-versatile | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── App defaults ─────────────────────────────────────────────────────────────
SCHOOL_NAME=Delhi Public School
