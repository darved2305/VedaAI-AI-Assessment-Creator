# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ────────────────────────────────────────────────────────────
dist/
build/

# ─── Environment variables — NEVER commit ────────────────────────────────────
# These files hold real credentials. Set production values in your
# deployment platform (Railway / Render → Environment Variables).
.env
.env.*
!.env.example

# ─── Uploaded files (user content) ──────────────────────────────────────────
uploads/*
!uploads/.gitkeep

# ─── Debug ───────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
