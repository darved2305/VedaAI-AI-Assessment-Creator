# ════════════════════════════════════════════════════════════════════════════
#  VedaAI Frontend — Environment Variables
#
#  HOW TO USE
#  ──────────
#  Local dev  : cp .env.example .env  then fill in values
#  Production : set these in your deployment platform BEFORE the build runs
#               (Vercel → Project Settings → Environment Variables)
#               NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
#
#  SECURITY
#  ────────
#  .env is gitignored. Never commit real values.
#  This file (.env.example) is safe to commit — it has no secrets.
# ════════════════════════════════════════════════════════════════════════════

# Backend REST API base URL (no trailing slash)
# Local dev  : http://localhost:4000/api
# Production : https://your-backend.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Backend WebSocket URL
# Local dev  : ws://localhost:4000/ws
# Production : wss://your-backend.railway.app/ws
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# ── UI defaults ─────────────────────────────────────────────────────────────
# Optional: display name shown in the top-right navbar
# If omitted, defaults to "Teacher"
NEXT_PUBLIC_TEACHER_NAME=
